# CertAuth Environment Configuration

# Flask Configuration
FLASK_ENV=production
# Optional: Set secret key for sessions (if used later)
# SECRET_KEY=your_secure_random_key_here

# AI Extraction (Google Gemini)
# Obtain a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Specify a preferred Gemini model (e.g., gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
